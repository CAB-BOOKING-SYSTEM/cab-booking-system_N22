{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@cab/shared-types": ["packages/shared-types/src/index.ts"],
      "@cab/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@cab/api-client": ["packages/api-client/src/index.ts"],
      "@cab/mobile-ui": ["packages/mobile-ui/src/index.ts"],
      "@cab/map-core": ["packages/map-core/src/index.ts"],
      "@cab/realtime": ["packages/realtime/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
