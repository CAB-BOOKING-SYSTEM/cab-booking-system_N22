# ==========================================
# CAB BOOKING SYSTEM - GLOBAL ENVIRONMENT
# ==========================================
NODE_ENV=development
LOG_LEVEL=info

# --- INFRASTRUCTURE CREDENTIALS ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_PORT=5432

MONGO_USER=admin
MONGO_PASSWORD=password123
MONGO_PORT=27017

REDIS_PORT=6379

RABBITMQ_USER=admin
RABBITMQ_PASS=password123
RABBITMQ_PORT_NODE=5672
RABBITMQ_PORT_UI=15672

# --- COMMON SECRETS ---
JWT_SECRET=supersecret
JWT_REFRESH_SECRET=supersecret-refresh-key-2024
INTERNAL_SECRET=cab-internal-2024
BCRYPT_ROUNDS=10

JWT_EXPIRES_IN=1m
JWT_REFRESH_EXPIRES_IN=7d

# --- SERVICE PORTS ---
GATEWAY_PORT=3000
AUTH_PORT=3001
BOOKING_PORT=3002
DRIVER_PORT=3003
NOTIFICATION_PORT=3004
PAYMENT_PORT=3005
PRICING_PORT=3006
REVIEW_PORT=3007
RIDE_PORT=3008
USER_PORT=3009
MATCHING_PORT=3010

# --- SERVICE URLs (HTTPS for Zero Trust) ---
FRONTEND_URL=http://localhost:3000
PRICING_SERVICE_URL=https://pricing-service:3006
DRIVER_SERVICE_URL=https://driver-service:3003
RIDE_SERVICE_URL=https://ride-service:3008
USER_SERVICE_URL=https://user-service:3009

# --- RABBITMQ URL ---
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672

# --- AI & FEATURE STORE ---
AI_MODEL_ENDPOINT=http://ai-model:8080
FEATURE_STORE_URL=http://feature-store:8080

# --- VNPAY CONFIG (Payment Service) ---
VNP_TMNCODE=75CCC85O
VNP_HASH_SECRET=D73GMMNTXMC73F8M4XJA3BJT2ZRPS37J
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Trả về Gateway (do đã chặn port trực tiếp) - Gateway dùng mTLS tạo HTTPS nội bộ, external là HTTP/HTTPS tuỳ setup, mặc định trả về Gateway
VNP_RETURN_URL=https://localhost:3000/api/payments/vnpay-return

# --- NOTIFICATION CONFIG ---
RABBITMQ_ENABLED=true
FCM_ENABLED=false
