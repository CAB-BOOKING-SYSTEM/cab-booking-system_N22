PORT=3006
NODE_ENV=development
DB_URL=postgresql://admin:password123@postgres:5432/pricing_db
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://admin:password123@rabbitmq:5672
LOG_LEVEL=info

# Dùng OSRM (miễn phí, không cần key) - đây là mặc định
MAP_PROVIDER=osrm

# Hoặc Google Maps (chính xác nhất, có traffic real-time)
# MAP_PROVIDER=google
# GOOGLE_MAPS_API_KEY=your_key_here

MAP_PROVIDER=tomtom
TOMTOM_API_KEY=
