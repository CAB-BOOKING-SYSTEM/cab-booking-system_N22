# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
DRIVER_SERVICE_URL=http://cab_driver:3003


# ==================== DATABASE (PostgreSQL) ====================
# Cách 1: Dùng DB_URL (khuyến nghị)
DB_URL=postgresql://admin:password123@localhost:5432/auth_db

# Cách 2: Hoặc dùng từng field riêng (nếu không dùng DB_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=password123
# DB_NAME=auth_db

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD= (nếu có)

# ==================== JWT ====================
JWT_SECRET=supersecret
JWT_REFRESH_SECRET=supersecret-refresh-key-2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== BCRYPT ====================
BCRYPT_ROUNDS=10

# ==================== LOGGING ====================
LOG_LEVEL=info
