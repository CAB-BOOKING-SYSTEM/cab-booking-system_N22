{
  "info": {
    "name": "Notification Service API",
    "_postman_id": "notification-service-cab-system",
    "description": "Postman Collection để test toàn bộ REST API của Notification Service (port 3004).\n\n**Base URL:** `http://localhost:3004`\n\n**Trước khi test:**\n- Đảm bảo service đang chạy (`docker-compose up` hoặc `node index.js`)\n- Thay biến `userId` và `notificationId` bằng giá trị thực từ MongoDB",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3004",
      "type": "string",
      "description": "Base URL của Notification Service"
    },
    {
      "key": "userId",
      "value": "cust_556677",
      "type": "string",
      "description": "ID người dùng — thay bằng userId thực trong MongoDB"
    },
    {
      "key": "notificationId",
      "value": "64abc1234567890abcdef000",
      "type": "string",
      "description": "MongoDB ObjectId của notification — thay bằng _id thực từ response của GET /notifications/:userId"
    }
  ],
  "item": [
    {
      "name": "🔍 Health & System",
      "item": [
        {
          "name": "Root — Service Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Kiểm tra service có đang chạy không. Trả về tên service, trạng thái DB, timestamp."
          },
          "response": [
            {
              "name": "200 OK — Service running",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Service is running smoothly!\",\n  \"timestamp\": \"2026-03-01T08:00:00.000Z\",\n  \"service\": \"Notification Service\",\n  \"db\": \"connected\"\n}"
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Health check endpoint — Docker/K8s dùng để kiểm tra service. Trả về 200 nếu DB connected, 503 nếu DB mất kết nối."
          },
          "response": [
            {
              "name": "200 OK — Healthy",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"healthy\",\n  \"db\": \"connected\",\n  \"socketOnlineUsers\": 3,\n  \"uptime\": 120.5,\n  \"timestamp\": \"2026-03-01T08:00:00.000Z\"\n}"
            },
            {
              "name": "503 — Unhealthy (DB disconnected)",
              "status": "Service Unavailable",
              "code": 503,
              "body": "{\n  \"status\": \"unhealthy\",\n  \"db\": \"disconnected\",\n  \"socketOnlineUsers\": 0,\n  \"uptime\": 5.1,\n  \"timestamp\": \"2026-03-01T08:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["metrics"]
            },
            "description": "Trả về Prometheus metrics dạng text/plain. Dùng cho Grafana scraping."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "GET — Lấy danh sách thông báo (mặc định)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response có success=true', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('total');",
                  "  pm.expect(json).to.have.property('page');",
                  "  pm.expect(json).to.have.property('totalPages');",
                  "});",
                  "",
                  "// Tự động lưu notificationId đầu tiên để dùng ở request sau",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('notificationId', json.data[0]._id);",
                  "  console.log('✅ Đã lưu notificationId:', json.data[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}"]
            },
            "description": "Lấy danh sách thông báo của user với phân trang mặc định (page=1, limit=20).\n\nTest script sẽ tự động lưu `_id` của thông báo đầu tiên vào biến `notificationId`."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"_id\": \"64abc1234567890abcdef001\",\n      \"userId\": \"cust_556677\",\n      \"userRole\": \"customer\",\n      \"type\": \"PaymentCompleted\",\n      \"title\": \"Thanh toán thành công\",\n      \"body\": \"Chuyến đi #RIDE_001 đã được thanh toán 85,000đ.\",\n      \"payload\": { \"rideId\": \"RIDE_001\", \"amount\": 85000 },\n      \"status\": \"sent\",\n      \"deliveryMethod\": [\"in_app_socket\", \"push_fcm\"],\n      \"retryCount\": 0,\n      \"readAt\": null,\n      \"createdAt\": \"2026-03-01T07:30:00.000Z\",\n      \"updatedAt\": \"2026-03-01T07:30:00.000Z\"\n    }\n  ],\n  \"total\": 1,\n  \"page\": 1,\n  \"totalPages\": 1\n}"
            }
          ]
        },
        {
          "name": "GET — Lấy thông báo (phân trang tùy chỉnh)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Trang hiện tại (default=1)"
                },
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Số bản ghi mỗi trang (default=20, max=100)"
                }
              ]
            },
            "description": "Lấy thông báo với phân trang tùy chỉnh: page=1, limit=5."
          },
          "response": []
        },
        {
          "name": "GET — Lấy thông báo (page=2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}?page=2&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Test phân trang trang 2."
          },
          "response": []
        },
        {
          "name": "GET — Unread Count (badge count)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response có unreadCount', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json).to.have.property('unreadCount');",
                  "  pm.expect(json.unreadCount).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}/unread-count",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}", "unread-count"]
            },
            "description": "Đếm số thông báo chưa đọc của user (status='sent'). Dùng hiển thị badge đỏ trên icon thông báo."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"userId\": \"cust_556677\",\n  \"unreadCount\": 5\n}"
            }
          ]
        },
        {
          "name": "PATCH — Đánh dấu 1 thông báo đã đọc",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 hoặc 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Response có data', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data.status).to.equal('read');",
                  "    pm.expect(json.data.readAt).to.not.be.null;",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{notificationId}}", "read"]
            },
            "description": "Đánh dấu một thông báo cụ thể là đã đọc.\n\n**Yêu cầu:** `userId` trong body để verify ownership (chống IDOR).\n\n**Lưu ý:** Thay `notificationId` bằng `_id` thực từ response GET phía trên, hoặc chạy request GET trước — test script sẽ tự lưu."
          },
          "response": [
            {
              "name": "200 OK — Đã đọc thành công",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"64abc1234567890abcdef001\",\n    \"userId\": \"cust_556677\",\n    \"status\": \"read\",\n    \"readAt\": \"2026-03-01T08:05:00.000Z\",\n    \"updatedAt\": \"2026-03-01T08:05:00.000Z\"\n  }\n}"
            },
            {
              "name": "400 — Thiếu userId trong body",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"userId là bắt buộc trong body.\"\n}"
            },
            {
              "name": "404 — Không tìm thấy hoặc không có quyền",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Không tìm thấy thông báo hoặc bạn không có quyền truy cập.\"\n}"
            }
          ]
        },
        {
          "name": "PATCH — Đánh dấu 1 thông báo đã đọc (thiếu userId — 400)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{notificationId}}", "read"]
            },
            "description": "Test case lỗi: không truyền userId trong body → expect 400 Bad Request."
          },
          "response": []
        },
        {
          "name": "PATCH — Đánh dấu TẤT CẢ đã đọc",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response có modifiedCount', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json).to.have.property('modifiedCount');",
                  "  pm.expect(json.modifiedCount).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}", "read-all"]
            },
            "description": "Đánh dấu toàn bộ thông báo chưa đọc (status='sent') của user thành 'read'.\n\nKhông cần body. Trả về số lượng bản ghi đã được cập nhật."
          },
          "response": [
            {
              "name": "200 OK — Đã đọc hết",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Đã đánh dấu đã đọc 5 thông báo.\",\n  \"modifiedCount\": 5\n}"
            },
            {
              "name": "200 OK — Không có thông báo chưa đọc",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Đã đánh dấu đã đọc 0 thông báo.\",\n  \"modifiedCount\": 0\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "⚠️ Edge Cases",
      "item": [
        {
          "name": "GET — userId không tồn tại",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/userId_khong_ton_tai",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "userId_khong_ton_tai"]
            },
            "description": "Trả về data=[] và total=0 (không phải 404 — đây là behavior đúng)."
          },
          "response": [
            {
              "name": "200 OK — Không có dữ liệu",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": [],\n  \"total\": 0,\n  \"page\": 1,\n  \"totalPages\": 0\n}"
            }
          ]
        },
        {
          "name": "GET — limit vượt max (100)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/{{userId}}?limit=9999",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "{{userId}}"],
              "query": [
                {
                  "key": "limit",
                  "value": "9999",
                  "description": "Controller sẽ clamp về max=100"
                }
              ]
            },
            "description": "Controller tự động clamp: `limit = Math.min(100, limit)`. Dù truyền 9999 vẫn chỉ trả về tối đa 100 bản ghi."
          },
          "response": []
        },
        {
          "name": "PATCH — notificationId không hợp lệ (ObjectId sai)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/notifications/invalid-object-id/read",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "invalid-object-id", "read"]
            },
            "description": "Test case: notificationId không phải MongoDB ObjectId hợp lệ → expect 500 hoặc 404."
          },
          "response": []
        },
        {
          "name": "GET — Unread count userId không tồn tại",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notifications/userId_fake_xyz/unread-count",
              "host": ["{{baseUrl}}"],
              "path": ["notifications", "userId_fake_xyz", "unread-count"]
            },
            "description": "userId không tồn tại → unreadCount = 0."
          },
          "response": [
            {
              "name": "200 OK — unreadCount = 0",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"userId\": \"userId_fake_xyz\",\n  \"unreadCount\": 0\n}"
            }
          ]
        }
      ]
    }
  ]
}
