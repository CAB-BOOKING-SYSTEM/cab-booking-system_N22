PORT=3004
NODE_ENV=development
DB_URL=mongodb://localhost:27017/notification_db
JWT_SECRET=your_jwt_secret_here
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_MAX_RETRIES=8
RABBITMQ_RETRY_DELAY_MS=3000

# Firebase FCM (optional in local dev)
FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=./src/config/cab-booking-firebase-adminsdk.json
FCM_DEV_TEST_TOKEN=