# ── Server ────────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Thay dòng cũ bằng dòng này để né lỗi ENOTFOUND
# DB_URL=mongodb://hle26625_db_user:admin123@cluster0-shard-00-00.nslaprk.mongodb.net:27017,cluster0-shard-00-01.nslaprk.mongodb.net:27017,cluster0-shard-00-02.nslaprk.mongodb.net:27017/cab-notifications?ssl=true&replicaSet=atlas-2w2u4b-shard-0&authSource=admin&retryWrites=true&w=majority&appName=notification
DB_URL=mongodb+srv://hle26625_db_user:aEuxe83lA4lX9OEk@notification.jrxenun.mongodb.net/?appName=Notification
# ── Message Broker (RabbitMQ) ─────────────────────────────────────────────────
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://localhost:5672

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Socket.IO ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Firebase FCM (Push Notification) ─────────────────────────────────────────
FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=./src/config/cab-booking-firebase-adminsdk.json
FCM_DEV_TEST_TOKEN=