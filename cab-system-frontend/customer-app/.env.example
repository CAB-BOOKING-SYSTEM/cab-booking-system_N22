# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT_MS=15000

# Service URLs - All through gateway at localhost:3000
EXPO_PUBLIC_USER_SERVICE_URL=https://localhost:3000/api/v1/users
EXPO_PUBLIC_BOOKING_SERVICE_URL=https://localhost:3000/api/bookings
EXPO_PUBLIC_PRICING_SERVICE_URL=https://localhost:3000/api/pricing
EXPO_PUBLIC_MATCHING_SERVICE_URL=https://localhost:3000/api/matching
EXPO_PUBLIC_NOTIFICATION_SERVICE_URL=https://localhost:3000/api/notifications
EXPO_PUBLIC_REVIEW_SERVICE_URL=https://localhost:3000/api/reviews

# Feature Flags
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_REALTIME=true

# Environment
EXPO_PUBLIC_ENVIRONMENT=development
